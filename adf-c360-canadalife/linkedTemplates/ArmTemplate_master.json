{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-c360-canadalife"
		},
		"ls_adls_c360_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsc360canadalife.dfs.core.windows.net/"
		},
		"ls_sql_control_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sql-c360-prod.database.windows.net"
		},
		"ls_sql_control_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "c360-control-db"
		},
		"trg_raw_landing_file_arrival_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/b68f64f5-49ae-4b7a-81c9-25cf642d4691/resourceGroups/rg-c360-prod/providers/Microsoft.Storage/storageAccounts/adlsc360canadalife"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-c360-canadalife_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_adls_c360_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_c360_properties_typeProperties_url')]"
					},
					"ls_sql_control_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_control_properties_typeProperties_server')]"
					},
					"ls_sql_control_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_control_properties_typeProperties_database')]"
					},
					"trg_raw_landing_file_arrival_properties_typeProperties_scope": {
						"value": "[parameters('trg_raw_landing_file_arrival_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}